<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>營業項目編號對應台北市土管歸組</title>
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 React 與 ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- 引入 Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- 引入 PapaParse 用於解析 Google Sheets CSV -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
    
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif, 'Microsoft JhengHei'; background-color: #f3f4f6; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 20px; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // --- 設定區：請在此輸入你的 Google Sheets 發佈連結 (CSV 格式) ---
        // 主資料連結
        const SHEET_URL_MAIN = "https://docs.google.com/spreadsheets/d/1OZIQFaNUUvMAgaPz9uLsoJdqcIXYgsIkT-d24uPWHXI/export?format=csv";
        // 組別資料連結
        const SHEET_URL_GROUP = "https://docs.google.com/spreadsheets/d/1p-N52gEcOHxo-Ml9sGOoe-Fnbmy7DeQT5-9fY4VeQ7w/export?format=csv";

        function App() {
            const [mainData, setMainData] = useState([]);
            const [groupData, setGroupData] = useState([]);
            const [isLoaded, setIsLoaded] = useState(false);
            const [errorMsg, setErrorMsg] = useState('');
            const [searchTerm, setSearchTerm] = useState('');
            const [filteredData, setFilteredData] = useState([]);
            const [selectedItem, setSelectedItem] = useState(null);
            const [showDropdown, setShowDropdown] = useState(false);
            const dropdownRef = useRef(null);

            useEffect(() => {
                function handleClickOutside(event) {
                    if (dropdownRef.current && !dropdownRef.current.contains(event.target)) {
                        setShowDropdown(false);
                    }
                }
                document.addEventListener("mousedown", handleClickOutside);
                return () => document.removeEventListener("mousedown", handleClickOutside);
            }, []);

            // 資料正規化 (去除欄位名稱的換行與空白)
            const normalizeData = (rawData) => {
                if (!rawData || !Array.isArray(rawData)) return [];
                return rawData.map(item => {
                    const newItem = {};
                    for (let key in item) {
                        const cleanKey = key.replace(/[\n\r\s]+/g, '');
                        newItem[cleanKey] = item[key];
                    }
                    return newItem;
                });
            };

            // 使用 PapaParse 抓取並解析 CSV
            const fetchCsv = (url) => {
                return new Promise((resolve, reject) => {
                    if (!url || url.includes("你的_")) {
                        resolve([]); 
                        return;
                    }
                    Papa.parse(url, {
                        download: true,
                        header: true,
                        complete: (results) => resolve(results.data),
                        error: (err) => reject(err)
                    });
                });
            };

            useEffect(() => {
                const loadData = async () => {
                    try {
                        if (SHEET_URL_MAIN.includes("你的_") || !SHEET_URL_MAIN) {
                            throw new Error("尚未設定 Google Sheets CSV 連結。");
                        }

                        const [mainRaw, groupRaw] = await Promise.all([
                            fetchCsv(SHEET_URL_MAIN),
                            fetchCsv(SHEET_URL_GROUP).catch(e => {
                                console.warn("組別資料載入失敗或未設定");
                                return [];
                            })
                        ]);

                        if (!mainRaw || mainRaw.length === 0) {
                            throw new Error("讀取到的資料為空，請確認試算表內容或權限是否已「發佈到網路」。");
                        }

                        setMainData(normalizeData(mainRaw));
                        setGroupData(normalizeData(groupRaw));
                        setIsLoaded(true);
                    } catch (error) {
                        console.error("載入失敗:", error);
                        setErrorMsg("無法從雲端資料庫讀取資料。請確認：\n1. Google 試算表已「發佈到網路」。\n2. 格式選擇為「CSV」。\n3. 連結正確且權限已開放。");
                    }
                };

                loadData();
            }, []);

            const handleSearch = (e) => {
                const value = e.target.value;
                setSearchTerm(value);
                setSelectedItem(null);

                if (value.trim() === '') {
                    setFilteredData([]);
                    setShowDropdown(false);
                    return;
                }

                const upperTerm = value.toUpperCase();
                const results = mainData.filter(item => {
                    const code = item['營業項目代碼'] ? String(item['營業項目代碼']).toUpperCase() : '';
                    const name = item['營業項目'] ? String(item['營業項目']).toUpperCase() : '';
                    return code.includes(upperTerm) || name.includes(upperTerm);
                });

                setFilteredData(results);
                setShowDropdown(true);
            };

            const selectItem = (item) => {
                setSearchTerm(item['營業項目代碼']);
                setSelectedItem(item);
                setShowDropdown(false);
            };

            const SearchIcon = () => (
                <svg xmlns="http://www.w3.org/2000/svg" className="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            );

            if (errorMsg) {
                return (
                    <div className="min-h-screen flex items-center justify-center p-4">
                        <div className="max-w-md w-full bg-white rounded-2xl shadow-xl p-8 border border-red-100">
                            <h1 className="text-xl font-bold text-red-600 mb-4 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" className="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                雲端連線失敗
                            </h1>
                            <p className="text-gray-600 whitespace-pre-wrap leading-relaxed bg-red-50 p-4 rounded-lg">{errorMsg}</p>
                        </div>
                    </div>
                );
            }

            if (!isLoaded) {
                return (
                    <div className="min-h-screen flex items-center justify-center">
                        <div className="flex flex-col items-center">
                            <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mb-4"></div>
                            <p className="text-gray-500 font-medium">正在連線至 Google 雲端資料庫...</p>
                        </div>
                    </div>
                );
            }

            return (
                <div className="min-h-screen p-4 md:p-8 max-w-5xl mx-auto">
                    <div className="mb-8">
                        <h1 className="text-3xl font-bold text-gray-800 mb-2">營業項目編號對應台北市土管歸組</h1>
                        <p className="text-sm text-gray-600 bg-gray-100 inline-block px-3 py-1 rounded-md mb-2">
                            資料更新：113.07.09經濟部營業項目總表_對應土管歸組及歸目
                        </p>
                        <p className="text-xs text-gray-400 mt-1">同步自 Google Sheets | 主資料: {mainData.length} 筆</p>
                    </div>

                    <div className="relative mb-8 z-50" ref={dropdownRef}>
                        <div className="relative">
                            <div className="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <SearchIcon />
                            </div>
                            <input
                                type="text"
                                className="block w-full pl-12 pr-4 py-4 bg-white border-2 border-transparent shadow-sm rounded-xl text-lg focus:ring-4 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all"
                                placeholder="輸入代碼或名稱..."
                                value={searchTerm}
                                onChange={handleSearch}
                                onFocus={() => { if (searchTerm) setShowDropdown(true); }}
                            />
                        </div>

                        {showDropdown && filteredData.length > 0 && (
                            <div className="absolute w-full mt-2 bg-white rounded-xl shadow-2xl border border-gray-100 max-h-80 overflow-y-auto custom-scrollbar">
                                {filteredData.slice(0, 50).map((item, index) => (
                                    <div 
                                        key={index}
                                        className="px-4 py-3 hover:bg-blue-50 cursor-pointer border-b border-gray-50 last:border-0 flex items-center gap-3"
                                        onClick={() => selectItem(item)}
                                    >
                                        <span className="font-mono font-bold text-blue-600 bg-blue-100 px-2 py-1 rounded text-sm">{item['營業項目代碼']}</span>
                                        <span className="text-gray-700 font-medium">{item['營業項目']}</span>
                                    </div>
                                ))}
                            </div>
                        )}
                    </div>

                    {selectedItem && (
                        <div className="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden animate-fade-in">
                            <div className="bg-gradient-to-r from-blue-600 to-indigo-700 px-6 py-6 text-white">
                                <span className="bg-white/20 text-white border border-white/30 px-3 py-1 rounded-lg font-mono text-xl font-bold block mb-2 w-fit">
                                    {selectedItem['營業項目代碼']}
                                </span>
                                <h2 className="text-3xl font-extrabold">{selectedItem['營業項目']}</h2>
                            </div>

                            <div className="p-6 md:p-8">
                                <div className="mb-6 bg-blue-50 p-6 rounded-xl border border-blue-100 text-blue-900">
                                    <h3 className="text-sm font-bold text-blue-800 mb-2 uppercase tracking-widest">定義內容</h3>
                                    <p className="text-lg leading-relaxed">{selectedItem['定義內容'] || '無詳細說明'}</p>
                                </div>

                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    {Object.entries(selectedItem).map(([key, value]) => {
                                        if (['營業項目代碼', '營業項目', '定義內容', ''].includes(key)) return null;
                                        return (
                                            <div key={key} className="bg-gray-50 p-5 rounded-xl border border-gray-100">
                                                <div className="text-xs font-bold text-gray-500 mb-1">{key}</div>
                                                <div className="text-gray-900 font-medium whitespace-pre-wrap">{value || '-'}</div>
                                            </div>
                                        );
                                    })}
                                </div>

                                {(() => {
                                    const targetGroupNum = selectedItem['土管歸組'];
                                    if (!targetGroupNum || groupData.length === 0) return null;
                                    const groupKeyName = Object.keys(groupData[0]).find(k => k.includes('組')) || '組別';
                                    const matchedItems = groupData.filter(g => String(g[groupKeyName]) === String(targetGroupNum));
                                    
                                    if (matchedItems.length === 0) return null;

                                    return (
                                        <div className="mt-8 bg-green-50 rounded-xl border border-green-200 overflow-hidden">
                                            <div className="px-6 py-4 bg-green-100/60 font-bold text-green-800">
                                                附屬組別資料 (第 {targetGroupNum} 組)
                                            </div>
                                            <div className="overflow-x-auto">
                                                <table className="w-full text-sm">
                                                    <thead className="bg-green-200/50 text-green-800 text-left">
                                                        <tr>
                                                            <th className="px-6 py-3">項目</th>
                                                            <th className="px-6 py-3">歸類項目</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        {matchedItems.map((g, i) => {
                                                            const keys = Object.keys(g).filter(k => k !== groupKeyName);
                                                            return (
                                                                <tr key={i} className="border-b border-green-100 bg-white">
                                                                    <td className="px-6 py-4 font-bold text-green-800 align-top">{g[keys[0]]}</td>
                                                                    <td className="px-6 py-4 whitespace-pre-wrap">{keys.slice(1).map(k => g[k]).join('\n')}</td>
                                                                </tr>
                                                            );
                                                        })}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    );
                                })()}
                            </div>
                        </div>
                    )}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>

    <style>
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
    </style>
</body>
</html>
